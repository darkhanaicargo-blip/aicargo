generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CargoGroup {
  id     Int     @id @default(autoincrement())
  name   String
  cargos Cargo[]
}

model Cargo {
  id            Int         @id @default(autoincrement())
  name          String
  slug          String      @unique
  ereemReceiver String
  ereemPhone    String
  ereemRegion   String  @default("")
  ereemAddress  String
  logoUrl          String?
  lastNotifiedAt        DateTime?
  notificationsEnabled  Boolean    @default(false)
  searchByPhone         Boolean    @default(false)
  tariff            String?
  announcement      String?
  contactInfo       String?
  bankName          String?
  bankAccountHolder String?
  bankAccountNumber String?
  bankTransferNote  String?
  arrivedLabel      String?
  createdAt         DateTime   @default(now())
  groupId       Int?
  group         CargoGroup? @relation(fields: [groupId], references: [id])
  users         User[]
  shipments     Shipment[]
  faqs          Faq[]
  notifications Notification[]
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String     @unique
  email     String?    @unique
  password  String
  role      Role       @default(USER)
  cargoId   Int
  cargo     Cargo      @relation(fields: [cargoId], references: [id])
  createdAt DateTime   @default(now())
  shipments Shipment[]

  @@index([cargoId])
}

model Shipment {
  id          Int      @id @default(autoincrement())
  trackCode   String
  description String?
  status      Status   @default(REGISTERED)
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  phone       String?
  adminPrice  Decimal? @db.Decimal(10, 2)
  adminNote   String?
  archived    Boolean  @default(false)
  cargoId     Int
  cargo       Cargo    @relation(fields: [cargoId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([trackCode, cargoId])
  @@index([cargoId, status])
  @@index([cargoId, updatedAt])
}

model Faq {
  id       Int    @id @default(autoincrement())
  question String
  answer   String
  order    Int    @default(0)
  cargoId  Int
  cargo    Cargo  @relation(fields: [cargoId], references: [id])
}

model Notification {
  id         Int          @id @default(autoincrement())
  cargoId    Int
  cargo      Cargo        @relation(fields: [cargoId], references: [id])
  type       NotifType
  title      String
  body       String
  read       Boolean      @default(false)
  archived   Boolean      @default(false)
  createdAt  DateTime     @default(now())

  @@index([cargoId, archived, read])
  @@index([cargoId, archived, createdAt])
}

model Otp {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
}

enum NotifType {
  NEW_SHIPMENT
  CROSS_CARGO
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Status {
  REGISTERED
  EREEN_ARRIVED
  ARRIVED
  PICKED_UP
}
