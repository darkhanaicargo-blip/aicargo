generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cargo {
  id            Int        @id @default(autoincrement())
  name          String
  slug          String     @unique
  ereemReceiver String
  ereemPhone    String
  ereemAddress  String
  logoUrl          String?
  lastNotifiedAt   DateTime?
  createdAt        DateTime   @default(now())
  users         User[]
  shipments     Shipment[]
  faqs          Faq[]
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String     @unique
  email     String?    @unique
  password  String
  role      Role       @default(USER)
  cargoId   Int
  cargo     Cargo      @relation(fields: [cargoId], references: [id])
  createdAt DateTime   @default(now())
  shipments Shipment[]
}

model Shipment {
  id          Int      @id @default(autoincrement())
  trackCode   String
  description String?
  status      Status   @default(REGISTERED)
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  phone       String?
  adminPrice  Decimal? @db.Decimal(10, 2)
  adminNote   String?
  archived    Boolean  @default(false)
  cargoId     Int
  cargo       Cargo    @relation(fields: [cargoId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([trackCode, cargoId])
}

model Faq {
  id       Int    @id @default(autoincrement())
  question String
  answer   String
  order    Int    @default(0)
  cargoId  Int
  cargo    Cargo  @relation(fields: [cargoId], references: [id])
}

model Otp {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Status {
  REGISTERED
  EREEN_ARRIVED
  ARRIVED
  PICKED_UP
}
